# ── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://iafacturas:CHANGE_ME@postgres:5432/iafacturas_db

POSTGRES_USER=iafacturas
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=iafacturas_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Seguridad ────────────────────────────────────────────────────────────────
# Generá con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_SECRET

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://iafacturas.dewoc.com

# ── IA — LLM ─────────────────────────────────────────────────────────────────
# OpenAI (opcional — fallback si Ollama no está disponible)
OPENAI_API_KEY=

# Ollama corre en el HOST del VPS (mismo patrón que document-ai)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_ENABLED=true

# ── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_app_password
SMTP_FROM=noreply@iafacturas.dewoc.com

# ── OCR ──────────────────────────────────────────────────────────────────────
# DPI para escaneos (200 recomendado para velocidad/calidad)
OCR_DPI=200
# DPI para fotos de celular (300 recomendado para preservar texto pequeño)
OCR_DPI_PHOTO=300
# Confianza mínima Tesseract por palabra (0-100). Palabras por debajo se descartan
OCR_CONF_THRESHOLD=30

# ── AFIP ─────────────────────────────────────────────────────────────────────
# TTL del caché Redis para respuestas de AFIP (segundos, default 3600 = 1 hora)
AFIP_CACHE_TTL=3600

# ── MercadoPago ──────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
